{
  "name": "@acme/api-client",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "HTTP API client for the monorepo",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf .turbo dist node_modules",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --check \"**/*.{ts,js,json,md}\" --ignore-path ../../.gitignore",
    "format:fix": "prettier --write \"**/*.{ts,js,json,md}\" --ignore-path ../../.gitignore",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "axios": "^1.13.6"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "peerDependencies": {
    "axios": "^1.13.6"
  },
  "peerDependenciesMeta": {
    "axios": {
      "optional": false
    }
  },
  "eslintConfig": {
    "extends": [
      "@acme/eslint-config/base"
    ],
    "parserOptions": {
      "project": true
    }
  },
  "prettier": "@acme/prettier-config",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "api",
    "client",
    "http",
    "axios"
  ],
  "author": "",
  "license": "MIT"
}
