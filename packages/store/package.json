{
  "name": "@acme/store",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Shared state management for the acme monorepo using Clean Architecture and Redux Toolkit",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./src/index.ts",
        "default": "./src/index.ts"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "files": [
    "dist",
    "src"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "clean": "rm -rf .turbo dist node_modules",
    "lint": "eslint . --max-warnings 0",
    "format": "prettier --check \"**/*.{ts,js,json,md}\" --ignore-path ../../.gitignore",
    "format:fix": "prettier --write \"**/*.{ts,js,json,md}\" --ignore-path ../../.gitignore",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm run build"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "react-redux": "^9.2.0",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@acme/eslint-config": "workspace:*",
    "@acme/prettier-config": "workspace:*",
    "@acme/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "@types/react": "catalog:react19",
    "@types/react-redux": "^7.1.33",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "eslintConfig": {
    "extends": [
      "@acme/eslint-config/base"
    ],
    "parserOptions": {
      "project": true
    }
  },
  "prettier": "@acme/prettier-config",
  "publishConfig": {
    "access": "public"
  },
  "keywords": [
    "store",
    "state",
    "redux"
  ],
  "author": "",
  "license": "MIT"
}
