{
  "name": "create-t3-turbo",
  "private": true,
  "engines": {
    "node": "^22.21.0",
    "pnpm": "^10.19.0"
  },
  "packageManager": "pnpm@10.19.0",
  "scripts": {
    "build": "turbo run build",
    "project:setup": "node scripts/setup/setup.js",
    "clean": "git clean -xdf node_modules",
    "clean:workspaces": "turbo run clean",
    "clean:all": "node scripts/setup/clean.js",
    "auth:generate": "pnpm -F @acme/auth generate",
    "db:push": "turbo -F @acme/db push",
    "db:studio": "turbo -F @acme/db studio",
    "dev": "turbo watch dev --filter=@acme/lms --filter=@acme/admin --filter=@acme/web --filter=@acme/landing --continue --concurrency=10",
    "dev:next": "turbo watch dev -F @acme/nextjs...",
    "format": "turbo run format --continue -- --cache --cache-location .cache/.prettiercache",
    "format:fix": "turbo run format --continue -- --write --cache --cache-location .cache/.prettiercache",
    "lint": "turbo run lint --continue -- --cache --cache-location .cache/.eslintcache",
    "lint:fix": "turbo run lint --continue -- --fix --cache --cache-location .cache/.eslintcache",
    "lint:staged": "lint-staged",
    "lint:ws": "pnpm dlx sherif@latest",
    "postinstall": "pnpm lint:ws",
    "typecheck": "turbo run typecheck",
    "ui-add": "turbo run ui-add",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "figma:styles": "node --env-file=.env scripts/figma-styles.js",
    "figma:export": "dotenv -e .env -- figma-export use-config scripts/generate-icon/.figmaexportrc.components.js",
    "icons:gallery": "dotenv -e .env -- node scripts/generate-icon/generate-gallery.js",
    "generate:icons": "pnpm figma:export && pnpm icons:gallery && pnpm -F @acme/ui format:fix",
    "tokens:build": "node scripts/fix-tokens.js && node sd.config.js",
    "prepare": "husky"
  },
  "devDependencies": {
    "@acme/prettier-config": "workspace:*",
    "@figma-export/cli": "^6.4.0",
    "@figma-export/output-components-as-svgr": "^6.4.0",
    "@figma-export/utils": "^6.4.0",
    "@svgr/cli": "^8.1.0",
    "@svgr/plugin-jsx": "^8.1.0",
    "@svgr/plugin-prettier": "^8.1.0",
    "@svgr/plugin-svgo": "^8.1.0",
    "@tokens-studio/sd-transforms": "^2.0.3",
    "@turbo/gen": "^2.5.8",
    "@types/leaflet": "^1.9.21",
    "dotenv-cli": "^10.0.0",
    "eslint": "9.38.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "catalog:",
    "style-dictionary": "^5.4.0",
    "turbo": "^2.5.8",
    "typescript": "catalog:"
  },
  "prettier": "@acme/prettier-config",
  "lint-staged": {
    "**/*.{ts,tsx,js,jsx}": [
      "pnpm exec eslint --flag unstable_native_nodejs_ts_config --fix",
      "pnpm exec prettier --write"
    ],
    "**/*.{json,md,css}": [
      "pnpm exec prettier --write"
    ]
  }
}
